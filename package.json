{
  "name": "uvt-events-service",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8799",
    "deploy": "./scripts/deploy.sh",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:seed:local": "wrangler d1 migrations apply uvt-events --local && wrangler d1 execute uvt-events --local --file=./db/seed.sql && wrangler d1 execute uvt-events --local --file=./db/seed.dev.sql",
    "db:migrate:local": "wrangler d1 migrations apply uvt-events --local",
    "db:migrate:remote": "wrangler d1 migrations apply uvt-events --remote"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.19",
    "@cloudflare/workers-types": "^4.20250601.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9",
    "wrangler": "^4.20.0"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.16.2",
    "hono": "^4.12.27",
    "zod": "^4.4.3"
  }
}
